---
const projects = [
  {
    title: 'Regional Church System',
    description: 'Multi-tenant platform managing congregational data across 24 churches with 1,000+ daily users.',
    tech: 'Laravel, FilamentPHP, React, MySQL, Docker',
    slug: 'regional-church-system',
  },
  {
    title: 'Hessah System',
    description: 'EdTech SaaS platform for private tutors — scheduling, payments, attendance, and performance analytics.',
    tech: 'Laravel, FilamentPHP, Livewire, Tailwind CSS',
    slug: 'hessah-system',
  },
  {
    title: 'ALReserve',
    description: 'Membership-based luxury accommodation booking platform for GCC travelers visiting UK, USA, and Europe.',
    tech: 'React 19, Hono, Supabase, TypeScript, Bun',
    slug: 'alreserve',
  },
];
---

<section id="work" class="max-w-6xl mx-auto px-6 py-20 md:py-28">
  <p class="text-sm uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3">Selected Work</p>
  <h2 class="text-3xl md:text-4xl font-serif text-stone-900 dark:text-stone-100 mb-12">Projects</h2>

  <div class="divide-y divide-stone-200 dark:divide-stone-800 border-t border-stone-200 dark:border-stone-800">
    {projects.map(({ title, description, tech, slug }) => (
      <a
        href={`/projects/${slug}`}
        class="group flex flex-col md:flex-row md:items-center justify-between py-6 md:py-8 hover:pl-2 transition-all"
      >
        <div class="flex-1">
          <h3 class="text-xl font-serif text-stone-900 dark:text-stone-100 group-hover:text-accent dark:group-hover:text-accent-light transition-colors">
            {title}
          </h3>
          <p class="text-stone-600 dark:text-stone-400 mt-1">{description}</p>
          <p class="text-sm text-stone-400 dark:text-stone-500 mt-2">{tech}</p>
        </div>
        <svg class="w-5 h-5 text-stone-400 group-hover:text-accent dark:group-hover:text-accent-light mt-3 md:mt-0 md:ml-6 shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
        </svg>
      </a>
    ))}
  </div>
</section>
