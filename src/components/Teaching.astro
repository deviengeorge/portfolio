---
const highlights = [
  { value: '300+', label: 'Students mentored across private and group sessions' },
  { value: '7', label: 'Week intensive internship curriculum designed' },
  { value: '30+', label: 'Student projects supervised and evaluated' },
];

const institutions = [
  'AMIT Learning',
  'Konecta',
  'StemEC',
  'RiskRice',
  'Senior Steps',
  'ITI (Guest)',
];
---

<section class="max-w-6xl mx-auto px-6 py-20 md:py-28">
  <p class="text-sm uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3">Education</p>
  <h2 class="text-3xl md:text-4xl font-serif text-stone-900 dark:text-stone-100 mb-12">Teaching & Mentoring</h2>

  <div class="grid md:grid-cols-3 gap-8 mb-12">
    {highlights.map(({ value, label }) => (
      <div class="border-l-2 border-accent pl-4">
        <p class="text-2xl font-serif text-stone-900 dark:text-stone-100">{value}</p>
        <p class="text-sm text-stone-600 dark:text-stone-400 mt-1">{label}</p>
      </div>
    ))}
  </div>

  <div>
    <h3 class="text-sm uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-4">Institutions</h3>
    <div class="flex flex-wrap gap-3">
      {institutions.map((name) => (
        <span class="text-sm px-3 py-1.5 border border-stone-200 dark:border-stone-700 text-stone-600 dark:text-stone-400 rounded-sm">
          {name}
        </span>
      ))}
    </div>
  </div>

  <div class="mt-12 p-6 border border-stone-200 dark:border-stone-800 bg-stone-100/50 dark:bg-stone-900/20">
    <p class="text-stone-600 dark:text-stone-400 italic font-serif text-lg leading-relaxed">
      "Teaching deepens understanding. Every class I teach makes me a better engineer — breaking complex systems into fundamentals forces clarity of thought."
    </p>
    <p class="text-sm text-stone-500 dark:text-stone-400 mt-3">— Devien George</p>
  </div>
</section>
