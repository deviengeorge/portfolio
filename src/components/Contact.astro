---
const links = [
  { href: 'mailto:deviengeorge99@gmail.com', label: 'deviengeorge99@gmail.com', icon: 'email' },
  { href: 'https://github.com/deviengeorge', label: 'github.com/deviengeorge', icon: 'github' },
  { href: 'https://linkedin.com/in/deviengeorge', label: 'linkedin.com/in/deviengeorge', icon: 'linkedin' },
  { href: 'https://x.com/devien_george', label: 'x.com/devien_george', icon: 'twitter' },
];
---

<section id="contact" class="max-w-5xl mx-auto px-6 py-20 md:py-28">
  <p class="text-sm uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3">Let's Connect</p>
  <h2 class="text-3xl md:text-4xl font-serif text-stone-900 dark:text-stone-100 mb-4">Get in Touch</h2>
  <p class="text-stone-600 dark:text-stone-400 mb-10 max-w-lg">
    Available for full-stack engineering roles, contract work, and technical consulting. Based in Cairo, Egypt — open to remote positions worldwide.
  </p>

  <div class="space-y-4">
    {links.map(({ href, label }) => (
      <a
        href={href}
        target={href.startsWith('mailto') ? undefined : '_blank'}
        rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
        class="flex items-center gap-3 text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 transition-colors group"
      >
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
        </svg>
        <span class="text-sm border-b border-transparent group-hover:border-current">{label}</span>
      </a>
    ))}
  </div>

  <div class="mt-10 inline-flex items-center gap-2 text-sm text-green-700 dark:text-green-400">
    <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
    Available for new projects
  </div>
</section>
