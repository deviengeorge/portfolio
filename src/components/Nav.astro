---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/#work', label: 'Work' },
  { href: '/#experience', label: 'Experience' },
  { href: '/blog', label: 'Blog' },
  { href: '/#contact', label: 'Contact' },
];
---

<nav class="sticky top-0 z-50 border-b border-stone-200 dark:border-stone-800 bg-stone-50/90 dark:bg-stone-950/90 backdrop-blur-sm">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-serif text-2xl text-stone-900 dark:text-stone-100 hover:text-accent transition-colors">
      DG
    </a>

    <div class="flex items-center gap-8">
      <ul class="hidden sm:flex items-center gap-6">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="text-sm text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 transition-colors"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
      <ThemeToggle />
    </div>
  </div>
</nav>
