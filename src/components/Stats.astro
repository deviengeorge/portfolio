---
const stats = [
  { value: '4+', label: 'Years Experience' },
  { value: '24', label: 'Organizations Served' },
  { value: '1K+', label: 'Daily Users' },
  { value: '300+', label: 'Students Taught' },
];
---

<section class="border-y border-stone-200 dark:border-stone-800 bg-stone-100/50 dark:bg-stone-900/30">
  <div class="max-w-6xl mx-auto px-6 py-10 grid grid-cols-2 md:grid-cols-4 gap-8">
    {stats.map(({ value, label }) => (
      <div class="text-center">
        <p class="text-3xl md:text-4xl font-serif text-stone-900 dark:text-stone-100">{value}</p>
        <p class="text-sm text-stone-500 dark:text-stone-400 mt-1">{label}</p>
      </div>
    ))}
  </div>
</section>
