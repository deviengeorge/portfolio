---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout
  title="تعلم البرمجة بالعربي — أول session مجانية | Devien George"
  description="دروس خصوصية في هندسة البرمجيات بالعربي — Data Structures, OOP, SQL, Web Development. أول ساعة مجانية بدون التزام."
  audience="students"
>
  <!-- Hero -->
  <section class="section-gap" style="padding-top: 3rem;">
    <div class="hero-glow"></div>
    <div class="container">
      <div class="animate-in">
        <span class="badge">لطلاب الجامعات</span>
      </div>

      <h1 class="animate-in delay-1" style="margin-top: 1.5rem;">
        الدكتور بيشرح بالإنجليزي
        <br />
        <span class="accent">وإنت تايه؟</span>
      </h1>

      <p style="font-size: 1.15rem; color: var(--text-secondary); margin-top: 1.25rem; max-width: 560px;" class="animate-in delay-2">
        هشرحلك البرمجة بالعربي — من Data Structures للـ OOP للـ Web Development.
        أول session ساعة كاملة مجانية. لو استفدت، كمّل. لو لأ، مفيش التزام.
      </p>

      <div style="margin-top: 2rem;" class="animate-in delay-3">
        <a
          href="https://wa.me/201281089983?text=%D9%85%D8%B1%D8%AD%D8%A8%D8%A7%D8%8C%20%D8%A3%D9%86%D8%A7%20%D8%B7%D8%A7%D9%84%D8%A8%20%D9%88%D8%B9%D8%A7%D9%8A%D8%B2%20%D8%A3%D8%AA%D8%B9%D9%84%D9%85"
          class="cta-btn"
          target="_blank"
          rel="noopener"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          كلمني على WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section-gap">
    <div class="container">
      <div class="grid-2" style="gap: 1.5rem;">
        <div class="card" style="text-align: center;">
          <div class="stat-value">+300</div>
          <p style="color: var(--text-secondary); margin-top: 0.5rem; font-size: 0.95rem;">طالب اتعلموا معايا</p>
        </div>
        <div class="card" style="text-align: center;">
          <div class="stat-value">+4</div>
          <p style="color: var(--text-secondary); margin-top: 0.5rem; font-size: 0.95rem;">سنين خبرة تدريس</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Topics -->
  <section class="section-gap">
    <div class="container">
      <h2>بدرّس إيه؟</h2>
      <div class="sep"></div>

      <div class="grid-2" style="margin-top: 1.5rem;">
        <div class="card">
          <h3>
            <span class="mono" style="color: var(--accent);">{'{'}</span>
            Data Structures
          </h3>
          <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.5rem;">
            Linked Lists, Trees, Graphs, Stacks, Queues — بأمثلة عملية وحل مسائل
          </p>
        </div>

        <div class="card">
          <h3>
            <span class="mono" style="color: var(--accent);">{'{'}</span>
            Algorithms
          </h3>
          <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.5rem;">
            Sorting, Searching, Big O, Dynamic Programming — شرح بالعربي بدون تعقيد
          </p>
        </div>

        <div class="card">
          <h3>
            <span class="mono" style="color: var(--accent);">{'{'}</span>
            OOP & Design Patterns
          </h3>
          <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.5rem;">
            Inheritance, Polymorphism, SOLID — هتفهمها مرة واحدة وللأبد
          </p>
        </div>

        <div class="card">
          <h3>
            <span class="mono" style="color: var(--accent);">{'{'}</span>
            SQL & Databases
          </h3>
          <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.5rem;">
            JOINs, Subqueries, Indexing, Normalization — من الصفر للـ advanced
          </p>
        </div>

        <div class="card">
          <h3>
            <span class="mono" style="color: var(--accent);">{'{'}</span>
            Web Development
          </h3>
          <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.5rem;">
            HTML, CSS, JavaScript, React — ابني أول موقع حقيقي
          </p>
        </div>

        <div class="card">
          <h3>
            <span class="mono" style="color: var(--accent);">{'{'}</span>
            Graduation Projects
          </h3>
          <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.5rem;">
            هساعدك تخطط وتنفذ مشروع التخرج — من الفكرة للـ deployment
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section-gap">
    <div class="container">
      <h2>إزاي بنشتغل؟</h2>
      <div class="sep"></div>

      <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: 1.5rem;">
        <div style="display: flex; gap: 1rem; align-items: flex-start;">
          <div class="step-number">١</div>
          <div>
            <h3>كلمني على WhatsApp</h3>
            <p style="color: var(--text-secondary); font-size: 0.9rem;">قولي إنت بتدرس إيه ومحتاج مساعدة في إيه</p>
          </div>
        </div>

        <div style="display: flex; gap: 1rem; align-items: flex-start;">
          <div class="step-number">٢</div>
          <div>
            <h3>أول session ساعة مجانية</h3>
            <p style="color: var(--text-secondary); font-size: 0.9rem;">نشتغل على مشكلتك الحقيقية — مش شرح نظري. هتخرج بحاجة تستخدمها فورًا</p>
          </div>
        </div>

        <div style="display: flex; gap: 1rem; align-items: flex-start;">
          <div class="step-number">٣</div>
          <div>
            <h3>لو استفدت — كمّل</h3>
            <p style="color: var(--text-secondary); font-size: 0.9rem;">$25 في الساعة، ادفع session بـ session. مفيش عقود أو التزام</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section-gap">
    <div class="container">
      <div class="card" style="text-align: center; padding: 2.5rem 1.5rem;">
        <p style="color: var(--text-secondary); font-size: 0.9rem;">سعر الساعة</p>
        <div style="margin-top: 0.5rem;">
          <span class="price">$25</span>
          <span class="price-currency"> / ساعة</span>
        </div>
        <div style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; align-items: center;">
          <p style="color: var(--text-secondary); font-size: 0.9rem;">
            <span class="accent">✓</span> أول session مجانية
          </p>
          <p style="color: var(--text-secondary); font-size: 0.9rem;">
            <span class="accent">✓</span> ادفع session بـ session
          </p>
          <p style="color: var(--text-secondary); font-size: 0.9rem;">
            <span class="accent">✓</span> باقة 4 sessions بـ $90 (وفّر $10)
          </p>
          <p style="color: var(--text-secondary); font-size: 0.9rem;">
            <span class="accent">✓</span> الدفع عن طريق Wise أو تحويل بنكي
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial / Trust -->
  <section class="section-gap">
    <div class="container">
      <h2>مين أنا؟</h2>
      <div class="sep"></div>

      <div style="margin-top: 1.5rem;">
        <p style="color: var(--text-secondary); font-size: 1rem; line-height: 2;">
          أنا <strong style="color: var(--text-primary);">Devien George</strong> — مهندس برمجيات بخبرة +4 سنين في بناء أنظمة حقيقية.
          درّست +300 طالب في أماكن زي AMIT Learning و ITI.
          مش بشرح نظري — بشرح من واقع الشغل الحقيقي.
        </p>
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem;">
        {['AMIT Learning', 'ITI', 'Konecta', 'StemEC', 'RiskRice', 'Senior Steps'].map(name => (
          <span style="font-size: 0.8rem; padding: 0.3rem 0.8rem; border-radius: 6px; background: var(--bg-card); border: 1px solid var(--border); color: var(--text-muted);">
            {name}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-gap" style="padding-bottom: 2rem;">
    <div class="container" style="text-align: center;">
      <h2>جاهز تبدأ؟</h2>
      <p style="color: var(--text-secondary); margin-top: 0.75rem;">
        كلمني دلوقتي وهنحدد موعد أول session مجانية
      </p>
      <div style="margin-top: 1.5rem;">
        <a
          href="https://wa.me/201281089983?text=%D9%85%D8%B1%D8%AD%D8%A8%D8%A7%D8%8C%20%D8%A3%D9%86%D8%A7%20%D8%B7%D8%A7%D9%84%D8%A8%20%D9%88%D8%B9%D8%A7%D9%8A%D8%B2%20%D8%A3%D8%AA%D8%B9%D9%84%D9%85"
          class="cta-btn"
          target="_blank"
          rel="noopener"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          ابدأ الآن — Session مجانية
        </a>
      </div>
    </div>
  </section>
</LandingLayout>
